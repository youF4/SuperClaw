{
    "name":  "superclaw",
    "version":  "0.2.1",
    "description":  "OpenClaw Chinese Desktop Client",
    "type":  "module",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "vite build",
                    "preview":  "vite preview",
                    "tauri":  "tauri",
                    "build:openclaw":  "cd openclaw \u0026\u0026 npm run build",
                    "build:all":  "npm run build:openclaw \u0026\u0026 npm run build \u0026\u0026 npm run tauri build",
                    "version:patch":  "powershell -NoProfile -File scripts/version.ps1 -Part patch",
                    "version:minor":  "powershell -NoProfile -File scripts/version.ps1 -Part minor",
                    "version:major":  "powershell -NoProfile -File scripts/version.ps1 -Part major"
                },
    "dependencies":  {
                         "@tauri-apps/api":  "^2.0.0",
                         "@tauri-apps/plugin-dialog":  "^2.0.0",
                         "@tauri-apps/plugin-fs":  "^2.0.0",
                         "@tauri-apps/plugin-notification":  "^2.0.0",
                         "@tauri-apps/plugin-os":  "^2.0.0",
                         "@tauri-apps/plugin-process":  "^2.0.0",
                         "@tauri-apps/plugin-shell":  "^2.0.0",
                         "@tauri-apps/plugin-updater":  "^2.0.0",
                         "dompurify":  "^3.4.2",
                         "highlight.js":  "^11.11.1",
                         "marked":  "^18.0.3",
                         "pinia":  "^3.0.0",
                         "vue":  "^3.5.0",
                         "vue-router":  "^4.5.0"
                     },
    "devDependencies":  {
                            "@tauri-apps/cli":  "^2.11.0",
                            "@types/dompurify":  "^3.0.5",
                            "@vitejs/plugin-vue":  "^5.2.4",
                            "typescript":  "^5.7.0",
                            "vite":  "^6.4.2",
                            "vue-tsc":  "^2.2.12"
                        }
}
