{
  "identifier": "default",
  "description": "Default capabilities for SuperClaw",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "shell:default",
    "shell:allow-open",
    "process:default",
    "process:allow-exit",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-stat",
    "fs:allow-read-dir",
    "fs:allow-copy-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "os:default",
    "os:allow-platform",
    "os:allow-version",
    "os:allow-arch",
    "os:allow-os-type",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
