{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "SuperClaw",
    "version":  "0.2.0",
    "identifier":  "com.superclaw.desktop",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "devUrl":  "http://localhost:1420",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "SuperClaw",
                                    "width":  1200,
                                    "height":  800,
                                    "minWidth":  800,
                                    "minHeight":  600,
                                    "resizable":  true,
                                    "fullscreen":  false,
                                    "center":  true
                                }
                            ],
                "security":  {
                                  "csp":  "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost blob: data:; connect-src 'self' http://127.0.0.1:22333 ws://127.0.0.1:22333; font-src 'self' data:;"
                              },
                "trayIcon":  {
                                 "iconPath":  "icons/icon.ico",
                                 "iconAsTemplate":  false
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  [
                                   "nsis"
                               ],
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.ico"
                            ],
                   "windows":  {
                                   "nsis":  {
                                                "installerIcon":  "icons/icon.ico",
                                                "installMode":  "perMachine",
                                                "languages":  [
                                                                  "SimpChinese"
                                                              ]
                                            },
                                   "webviewInstallMode":  {
                                                              "type":  "embedBootstrapper"
                                                          }
                               }
               }
}
