{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "SuperClaw",
    "version":  "0.2.1",
    "identifier":  "com.superclaw.desktop",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "devUrl":  "http://localhost:1420",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "SuperClaw",
                                    "width":  1200,
                                    "height":  800,
                                    "minWidth":  800,
                                    "minHeight":  600,
                                    "resizable":  true,
                                    "fullscreen":  false,
                                    "center":  true
                                }
                            ],
                "security":  {
                                 "csp":  "default-src \u0027self\u0027; script-src \u0027self\u0027; style-src \u0027self\u0027 \u0027unsafe-inline\u0027; img-src \u0027self\u0027 asset: https://asset.localhost blob: data:; connect-src \u0027self\u0027 http://127.0.0.1:22333 ws://127.0.0.1:22333; font-src \u0027self\u0027 data:;"
                             },
                "trayIcon":  {
                                 "iconPath":  "icons/icon.ico",
                                 "iconAsTemplate":  false
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  [
                                   "nsis"
                               ],
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.ico"
                            ],
                   "resources":  {
                                     "../openclaw-dist":  "openclaw/"
                                 },
                   "windows":  {
                                   "nsis":  {
                                                "installerIcon":  "icons/icon.ico",
                                                "installMode":  "perMachine",
                                                "languages":  [
                                                                  "SimpChinese"
                                                              ]
                                            },
                                   "webviewInstallMode":  {
                                                              "type":  "downloadBootstrapper"
                                                          }
                               }
               }
}
